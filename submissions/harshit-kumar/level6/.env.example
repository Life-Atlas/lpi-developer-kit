# Factory Knowledge Graph — Environment Variables
# Copy this file to .env and fill in your Neo4j Aura credentials
# NEVER commit your real .env file (it is in .gitignore)

# Neo4j Aura Free connection string
# Get from: console.neo4j.io → your instance → Connect
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io

# Default username for Neo4j Aura is "neo4j"
NEO4J_USER=neo4j

# The password you set when creating the Aura instance
NEO4J_PASSWORD=your-secure-password-here
